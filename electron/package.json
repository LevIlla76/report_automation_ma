{
  "name": "report-automation",
  "version": "1.0.3",
  "description": "Network Report Automation System",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win --x64",
    "build:publish": "electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "com.levillA76.report-automation",
    "productName": "OCR Report Automation",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/.cache"
    ],
    "extraResources": [
      {
        "from": "../backend_dist/",
        "to": "backend_dist/",
        "filter": ["**/*"]
      },
      {
        "from": "../frontend/out/",
        "to": "frontend_out/",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OCR Report Automation",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "LevIlla76",
      "repo": "report_automation_ma"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "electron-log": "^5.2.4",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "electron": "^33.4.0",
    "electron-builder": "^26.8.2"
  }
}
